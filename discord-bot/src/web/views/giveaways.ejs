<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="shell">
    <%- include('partials/nav') %>
    <main class="main">
      <div class="crumb"><a href="/dashboard">Your Servers</a> / <a href="/dashboard/<%= guild.id %>"><%= guild.name %></a> / Giveaways</div>
      <div class="topbar">
        <div>
          <h1>Giveaways</h1>
          <div class="subtitle">Start new ones with <code>/giveaway start</code> in Discord</div>
        </div>
      </div>

      <% if (giveaways.length === 0) { %>
        <div class="empty-state">
          <div class="glyph">🎉</div>
          <p>No giveaways yet. Run <code>/giveaway start</code> in your server to create one.</p>
        </div>
      <% } else { %>
        <table>
          <thead><tr><th>Prize</th><th>Winners</th><th>Entries</th><th>Status</th><th>Ends / Ended</th></tr></thead>
          <tbody>
            <% giveaways.forEach(g => { %>
              <tr>
                <td><%= g.prize %></td>
                <td><%= g.winners_count %></td>
                <td><%= g.entryCount %></td>
                <td><span class="badge <%= g.ended ? 'badge-ended' : 'badge-active' %>"><%= g.ended ? 'Ended' : 'Active' %></span></td>
                <td><%= new Date(g.end_time).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </main>
  </div>
</body>
</html>
