<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="shell">
    <%- include('partials/nav') %>
    <main class="main">
      <div class="crumb"><a href="/dashboard">Your Servers</a> / <a href="/dashboard/<%= guild.id %>"><%= guild.name %></a> / Invites</div>
      <div class="topbar">
        <div>
          <h1>Invite Leaderboard</h1>
          <div class="subtitle">Who's brought in the most members</div>
        </div>
      </div>

      <% if (top.length === 0) { %>
        <div class="empty-state">
          <div class="glyph">📨</div>
          <p>No tracked invites yet.</p>
        </div>
      <% } else { %>
        <table>
          <thead><tr><th>#</th><th>Inviter</th><th>Invites</th></tr></thead>
          <tbody>
            <% top.forEach((row, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td class="mono"><%= row.inviter_id %></td>
                <td><%= row.uses %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </main>
  </div>
</body>
</html>
