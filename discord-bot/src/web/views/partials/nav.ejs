<aside class="sidebar">
  <div class="sidebar-header">
    <div class="brand-mark">TH</div>
    <span>Hangout Bot</span>
  </div>

  <a href="/dashboard" class="nav-link <%= path === '/dashboard' ? 'active' : '' %>">◧ Your Servers</a>
  <% if (typeof guild !== 'undefined') { %>
    <a href="/dashboard/<%= guild.id %>" class="nav-link <%= path === '/dashboard/' + guild.id ? 'active' : '' %>">⌁ Control Panel</a>
    <a href="/dashboard/<%= guild.id %>/leaderboard" class="nav-link <%= path.includes('/leaderboard') ? 'active' : '' %>">🏆 Leaderboard</a>
    <a href="/dashboard/<%= guild.id %>/invites" class="nav-link <%= path.includes('/invites') ? 'active' : '' %>">📨 Invites</a>
    <a href="/dashboard/<%= guild.id %>/reaction-roles" class="nav-link <%= path.includes('/reaction-roles') ? 'active' : '' %>">🏷️ Reaction Roles</a>
    <a href="/dashboard/<%= guild.id %>/embed-generator" class="nav-link <%= path.includes('/embed-generator') ? 'active' : '' %>">🖼️ Embed Generator</a>
    <a href="/dashboard/<%= guild.id %>/giveaways" class="nav-link <%= path.includes('/giveaways') ? 'active' : '' %>">🎉 Giveaways</a>
    <a href="/dashboard/<%= guild.id %>/warnings" class="nav-link <%= path.includes('/warnings') ? 'active' : '' %>">⚠ Warnings</a>
  <% } %>

  <div class="sidebar-footer">
    <div class="user-chip">
      <div class="avatar-dot"><%= user.username.charAt(0).toUpperCase() %></div>
      <span><%= user.username %></span>
    </div>
    <a href="/auth/logout" class="nav-link" style="margin-top:4px;">↩ Log out</a>
  </div>
</aside>
