DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
DISCORD_CLIENT_SECRET=your_application_client_secret_here
SESSION_SECRET=any_long_random_string_for_cookie_signing
# Full public URL where this bot is hosted, no trailing slash.
# Must exactly match a Redirect URI you add in Discord Developer Portal > OAuth2.
DASHBOARD_URL=https://your-app.onrender.com
# Optional: set for instant slash-command updates in one server while testing.
# Leave blank to deploy commands globally (takes up to 1 hour to show up everywhere).
GUILD_ID=
